%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 85baba632ea3086499e53d211ed4c41a, type: 3}
  m_Name: Day1 - Lola Mom Intro
  m_EditorClassIdentifier: 
  lines:
  - speaker: 3
    text: Here is the Player Status System!
    useSpotlight: 1
    spotlightIndex: 0
    dependsOnBudget: 0
    requiredBudget: 0
  - speaker: 3
    text: "this is where you will see Alex\u2019s Happiness Meter which you have
      to watch closely so stress doesn't take over Alex\u2019s decision making, make
      sure it doesn't drop below 30%! "
    useSpotlight: 1
    spotlightIndex: 1
    dependsOnBudget: 0
    requiredBudget: 0
  - speaker: 3
    text: Next to the Happiness meter is the Savings Meter. Here you get to see and
      track how far or near you are from your savings goal!
    useSpotlight: 1
    spotlightIndex: 2
    dependsOnBudget: 0
    requiredBudget: 0
  - speaker: 3
    text: 'Moving on to your expenses, since you chose [METHOD] this is your expense
      tab:'
    useSpotlight: 1
    spotlightIndex: 3
    dependsOnBudget: 0
    requiredBudget: 0
  - speaker: 3
    text: Now, both your needs and wants are in one tab.
    useSpotlight: 1
    spotlightIndex: 4
    dependsOnBudget: 1
    requiredBudget: 1
  - speaker: 3
    text: "Now be careful! Just because you can spend more on wants doesn\u2019t
      mean you should! "
    useSpotlight: 1
    spotlightIndex: 4
    dependsOnBudget: 1
    requiredBudget: 1
  - speaker: 3
    text: 'Here, your Needs and Wants are separated into 2 tabs, less confusion but
      still try not to over spend! '
    useSpotlight: 1
    spotlightIndex: 4
    dependsOnBudget: 1
    requiredBudget: 2
  - speaker: 3
    text: For your savings tab, this will show how much you leave unspent or saved
      from your allowance.
    useSpotlight: 1
    spotlightIndex: 4
    dependsOnBudget: 0
    requiredBudget: 0
  - speaker: 3
    text: "And Here is the Events tab, for now this is empty since you won\u2019t
      need it but later on as a college student, you will!"
    useSpotlight: 1
    spotlightIndex: 6
    dependsOnBudget: 0
    requiredBudget: 0
