  m_Name: Day 13 - Dialogue
  m_EditorClassIdentifier: 
  lines:
  - expression: 0
    speaker: 0
    text: "*Alex\u2019s room. Boyet sits on a chair, holding a plastic container
      of home-cooked soup*"
    useSpotlight: 0
    spotlightIndex: 0
    dependsOnBudget: 0
    requiredBudget: 0
    waitForButton: 0
    lolaStep: 0
    requiresValidAllocation: 0
  - expression: 0
    speaker: 3
    text: "My mom made this. It\u2019s mostly broth. She doesn\u2019t know\u2026
      she just thinks you have a bad flu"
    useSpotlight: 0
    spotlightIndex: 0
    dependsOnBudget: 0
    requiredBudget: 0
    waitForButton: 0
    lolaStep: 0
    requiresValidAllocation: 0
  - expression: 2
    speaker: 1
    text: "Thank you, and I\u2019m sorry, Boyet. For all the lies. I just didn\u2019t
      want our final moments to be like this"
    useSpotlight: 0
    spotlightIndex: 0
    dependsOnBudget: 0
    requiredBudget: 0
    waitForButton: 0
    lolaStep: 0
    requiresValidAllocation: 0
  - expression: 0
    speaker: 3
    text: "I know. I stayed up all night thinking about it. With how much you\u2019re
      suffering, it wasn\u2019t worth staying mad. I couldn\u2019t let you go through
      this alone, any longer"
    useSpotlight: 0
    spotlightIndex: 0
    dependsOnBudget: 0
    requiredBudget: 0
    waitForButton: 0
    lolaStep: 0
    requiresValidAllocation: 0
  - expression: 0
    speaker: 4
    text: P800 ALLOWANCE RECEIVED
    useSpotlight: 0
    spotlightIndex: 0
